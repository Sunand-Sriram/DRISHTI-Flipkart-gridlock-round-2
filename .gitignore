# ───────── Python / backend ─────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# uploads (runtime) — not needed in repo
drishti/uploads/

# ───────── Large ML assets — NOT committed (see DEPLOY.md) ─────────
drishti/models/
drishti/datasets/
*.pt
*.onnx
*.zip
*.log
catboost_info/

# training-run outputs are huge — ignore everything under runs/ EXCEPT the
# pre-generated demo evidence images (so the deployed site shows real photos)
drishti/runs/*
!drishti/runs/drishti/
drishti/runs/drishti/*
!drishti/runs/drishti/*.jpg

# NOTE: we intentionally DO commit the seeded demo DB + outbox so the site shows
# data on a fresh clone without needing datasets/models:
#   drishti/api/drishti.db  and  drishti/api/outbox/  are kept.

# ───────── Node / frontend ─────────
web/node_modules/
web/dist/
web/.vite/
npm-debug.log*

# ───────── Env / secrets ─────────
.env
.env.local
.env.*.local

# ───────── OS / editor ─────────
.DS_Store
Thumbs.db
.idea/
.vscode/
